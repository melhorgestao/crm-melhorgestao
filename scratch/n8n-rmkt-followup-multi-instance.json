      "parameters": {
        "jsCode": "const inst = $('Split por Instância').item.json;\nconst resp = $input.first().json;\nconst state = resp?.instance?.state || resp?.state || null;\nreturn [{ json: { ...inst, _skip: state !== 'open', _detected_state: state || 'unreachable' } }];"
      },
