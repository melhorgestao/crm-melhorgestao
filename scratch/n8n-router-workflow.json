        "jsCode": "// Se for áudio, chama edge transcrever-audio. Senão, repassa msg_text original.\nconst e = $('EXTRAI CAMPOS').item.json;\nconst msgText = e.msg_text || '';\nconst msgType = e.message_type || '';\nconst msgId   = e.msg_id || '';\nconst instId  = $('RESOLVE CONFIG INSTÂNCIA').item.json.instancia_uuid;\n\nif (msgType !== 'audioMessage') {\n  return [{ json: { texto_final: msgText, foi_transcrito: false, tipo_origem: msgType || 'text' } }];\n}\n\nif (!msgId || !instId) {\n  return [{ json: { texto_final: '(áudio recebido sem msg_id — não foi possível transcrever)', foi_transcrito: false, tipo_origem: 'audio' } }];\n}\n\ntry {\n  const r = await fetch('https://epreaawpvxrpqqthcczu.supabase.co/functions/v1/transcrever-audio', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVwcmVhYXdwdnhycHFxdGhjY3p1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcxMjM5MDIsImV4cCI6MjA5MjY5OTkwMn0.VEQb1fk7JRIB1KXtHZGcmLKKMWJvkpG1fINB3mdPn0E',\n      'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVwcmVhYXdwdnhycHFxdGhjY3p1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcxMjM5MDIsImV4cCI6MjA5MjY5OTkwMn0.VEQb1fk7JRIB1KXtHZGcmLKKMWJvkpG1fINB3mdPn0E'\n    },\n    body: JSON.stringify({ instancia_id: instId, msg_id: msgId })\n  });\n  const data = await r.json();\n  if (!data.ok) {\n    return [{ json: { texto_final: '(áudio recebido — falha ao transcrever: ' + (data.error || 'erro desconhecido') + ')', foi_transcrito: false, tipo_origem: 'audio', erro: data.error } }];\n  }\n  const texto = (data.texto || '').trim();\n  if (!texto) {\n    return [{ json: { texto_final: '(áudio sem voz reconhecida)', foi_transcrito: false, tipo_origem: 'audio' } }];\n  }\n  return [{ json: { texto_final: texto, foi_transcrito: true, tipo_origem: 'audio' } }];\n} catch (err) {\n  return [{ json: { texto_final: '(áudio recebido — erro na transcrição: ' + err.message + ')', foi_transcrito: false, tipo_origem: 'audio' } }];\n}"
