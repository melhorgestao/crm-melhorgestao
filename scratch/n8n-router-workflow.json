{
  "name": "Router (Evolution Webhook)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "router-evolution",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Evolution",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -2200,
        400
      ],
      "webhookId": "router-evolution"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "instancia_nome",
              "value": "={{ $json.body?.instance || $json.instance }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "telefone_raw",
              "value": "={{ $json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '' }}",
              "type": "string"
            },
            {
              "id": "3",
              "name": "telefone_clean",
              "value": "={{ ($json.body?.data?.key?.remoteJid || $json.data?.key?.remoteJid || '').replace(/\\D/g, '').replace(/^55(\\d{10,11})$/, '55$1') }}",
              "type": "string"
            },
            {
              "id": "4",
              "name": "from_me",
              "value": "={{ $json.body?.data?.key?.fromMe || $json.data?.key?.fromMe || false }}",
              "type": "boolean"
            },
            {
              "id": "5",
              "name": "msg_text",
              "value": "={{ $json.body?.data?.message?.conversation || $json.body?.data?.message?.extendedTextMessage?.text || $json.data?.message?.conversation || $json.data?.message?.extendedTextMessage?.text || '' }}",
              "type": "string"
            },
            {
              "id": "6",
              "name": "message_type",
              "value": "={{ Object.keys($json.body?.data?.message || $json.data?.message || {})[0] || 'unknown' }}",
              "type": "string"
            },
            {
              "id": "7",
              "name": "push_name",
              "value": "={{ $json.body?.data?.pushName || $json.data?.pushName || '' }}",
              "type": "string"
            },
            {
              "id": "8",
              "name": "msg_id",
              "value": "={{ $json.body?.data?.key?.id || $json.data?.key?.id || '' }}",
              "type": "string"
            },
            {
              "id": "9",
              "name": "ctwa_source_id",
              "value": "={{ $json.body?.data?.message?.messageContextInfo?.ctwaContext?.sourceId || $json.data?.message?.messageContextInfo?.ctwaContext?.sourceId || null }}",
              "type": "string"
            },
            {
              "id": "10",
              "name": "ctwa_source_url",
              "value": "={{ $json.body?.data?.message?.messageContextInfo?.ctwaContext?.sourceUrl || $json.data?.message?.messageContextInfo?.ctwaContext?.sourceUrl || null }}",
              "type": "string"
            },
            {
              "id": "11",
              "name": "evolution_base_url",
              "value": "https://evo.melhorgestao.online",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "extract-fields",
      "name": "EXTRAI CAMPOS",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -1980,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://epreaawpvxrpqqthcczu.supabase.co/rest/v1/instancias",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "ativo",
              "value": "eq.true"
            },
            {
              "name": "status",
              "value": "eq.ativo"
            },
            {
              "name": "evolution_apikey",
              "value": "not.is.null"
            },
            {
              "name": "select",
              "value": "id,nome,evolution_instance,evolution_url,evolution_apikey"
            }
          ]
        },
        "options": {}
      },
      "id": "get-instancias-router",
      "name": "GET INSTÂNCIAS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1870,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Resolve config da instância que recebeu a mensagem (matching pelo evolution_instance)\nconst instancia_nome = $('EXTRAI CAMPOS').item.json.instancia_nome;\nconst instancias = $input.all().map(i => i.json);\nconst inst = instancias.find(i => i.evolution_instance === instancia_nome) || null;\nreturn [{\n  json: {\n    ...$('EXTRAI CAMPOS').item.json,\n    instancia_uuid: inst?.id || null,\n    evolution_apikey: inst?.evolution_apikey || null,\n    evolution_url: inst?.evolution_url || $('EXTRAI CAMPOS').item.json.evolution_base_url,\n    _instancia_found: inst !== null,\n  }\n}];"
      },
      "id": "resolve-inst-router",
      "name": "RESOLVE CONFIG INSTÂNCIA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1760,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "valid-type",
              "leftValue": "conversation,extendedTextMessage,audioMessage,imageMessage,videoMessage,documentMessage",
              "rightValue": "={{ $json.message_type }}",
              "operator": {
                "type": "string",
                "operation": "contains",
                "rightType": "any"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-types",
      "name": "TIPO ACEITO?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -1760,
        400
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"ignored\",\"reason\":\"unsupported_message_type\"}"
